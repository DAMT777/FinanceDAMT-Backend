{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/financedamt-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },

  "DatabaseProvider": "PostgreSQL",

  "ConnectionStrings": {
    "DefaultConnection": "",
    "PostgreSQL": "",
    "SqlServer": ""
  },

  "JwtSettings": {
    "Secret": "",
    "Issuer": "FinanceDAMT",
    "Audience": "FinanceDAMT",
    "AccessTokenExpirationMinutes": 60,
    "RefreshTokenExpirationDays": 7
  },

  "SmtpSettings": {
    "Host": "",
    "Port": 587,
    "User": "",
    "Pass": "",
    "FromEmail": "noreply@financedamt.com",
    "FromName": "FinanceDAMT"
  },

  "BlobStorage": {
    "ConnectionString": "",
    "ContainerName": "receipts"
  },

  "RedisSettings": {
    "Connection": "localhost:6379"
  },

  "Groq": {
    "ApiKey": "",
    "BaseUrl": "https://api.groq.com/openai/v1",
    "FastModel": "llama-3.1-8b-instant",
    "SmartModel": "llama-3.3-70b-versatile"
  },

  "BackgroundJobs": {
    "MonthlySummaryCron": "0 7 1 * *",
    "DailyBudgetCheckCron": "0 8 * * *",
    "InactiveReminderCron": "0 9 * * *",
    "MonthlyScoreCron": "0 6 1 * *",
    "InactivityDays": 7
  },

  "AppSettings": {
    "FrontendBaseUrl": "http://localhost:19006"
  },

  "AllowedHosts": "*"
}
